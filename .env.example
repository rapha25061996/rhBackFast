# Application
APP_NAME="RH Management System"
APP_VERSION="1.0.0"
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rh_db

# Security
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://hr-m-syst.vercel.app"]

# Security System
# Enable/disable authentication (JWT token validation)
# Set to False for testing/development without authentication
AUTHENTICATION_ENABLED=True

# Enable/disable permission checks
# Set to False for development to bypass permission requirements
PERMISSION_CHECK_ENABLED=True

# Permissions
# Auto-create CRUD permissions for all models at startup
# Set to False in production (use migrations instead)
AUTO_CREATE_PERMISSIONS=True

# Email/SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@company.com
# SMTP_TLS=True
# NOTIFICATIONS_ENABLED=False

# Payroll Configuration - INSS Rates (Employer)
PAYROLL__INSS_PENSION_RATE=0.06
PAYROLL__INSS_PENSION_CAP=27000
PAYROLL__INSS_RISK_RATE=0.06
PAYROLL__INSS_RISK_CAP=2400

# Payroll Configuration - INSS Rates (Employee)
PAYROLL__INSS_EMPLOYEE_RATE=0.04
PAYROLL__INSS_EMPLOYEE_CAP=18000

# Payroll Configuration - IRE Brackets (JSON format)
# PAYROLL__IRE_BRACKETS=[{"min": 0, "max": 150000, "rate": 0.0}, {"min": 150000, "max": 300000, "rate": 0.2}, {"min": 300000, "max": "inf", "rate": 0.3}]

# Payroll Configuration - Family Allowance Scale (JSON format)
# PAYROLL__FAMILY_ALLOWANCE_SCALE=[{"children": 0, "amount": 0}, {"children": 1, "amount": 5000}, {"children": 2, "amount": 10000}, {"children": 3, "amount": 15000}, {"children_additional": 3000}]

# Audit System
# Enable/disable audit logging
AUDIT_ENABLED=True

# Days to keep audit logs (older logs can be archived/deleted)
AUDIT_RETENTION_DAYS=90

# Paths to skip from audit logging (comma-separated)
# AUDIT_SKIP_PATHS=["/docs","/redoc","/openapi.json","/favicon.ico","/health","/metrics","/static"]

# Sensitive fields to mask in audit logs (comma-separated)
# AUDIT_SENSITIVE_FIELDS=["password","token","secret","api_key","credit_card"]

# Leave Management Configuration
# Default country code for holiday calculations (ISO 3166-1 alpha-2).
# The `holidays` Python library is queried on-the-fly; nothing is stored in DB.
CONGE_DEFAULT_COUNTRY_CODE=BI

# Default language for holiday names (fr, en, ...). Falls back to the library
# default if the language is not supported for the given country.
CONGE_HOLIDAY_LANGUAGE=fr

# Create the default CONGE workflow (statuses, types, steps, actions) at startup
CONGE_INIT_DEFAULTS=True
PAIE_INIT_DEFAULTS=True
